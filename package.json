{
  "name": "payload-db-surrealdb",
  "version": "0.3.0",
  "description": "Alpha Payload CMS database adapter for SurrealDB.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples/basic",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "smoke": "npm run build && node smoke.mjs",
    "test:transactions": "npm run build && node tests/transactions-versions.mjs",
    "smoke:relationships": "npm run build && node relationship-smoke.mjs"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "surrealdb",
    "database-adapter",
    "cms"
  ],
  "author": "Isaiah Dahl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IsaiahDahl/payload-db-surrealdb.git"
  },
  "bugs": {
    "url": "https://github.com/IsaiahDahl/payload-db-surrealdb/issues"
  },
  "homepage": "https://github.com/IsaiahDahl/payload-db-surrealdb#readme",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "payload": ">=3.0.0 <4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "payload": "^3.84.1",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
